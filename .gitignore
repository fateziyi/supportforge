# ============================
# SupportForge .gitignore
# Monorepo: Frontend + Backend
# ============================

# ── OS & Editor ──────────────
.DS_Store
Thumbs.db
*.swp
*.swo
*~
.idea/
.vscode/
*.sublime-project
*.sublime-workspace

# ── Environment & Secrets ────
.env
.env.local
.env.*.local
*.pem
*.key
*.secret

# ── Python / Backend ─────────
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg
*.egg-info/
dist/
build/
.eggs/
*.manifest
*.spec

# Poetry
poetry.lock  # 如需锁定依赖版本可取消此行

# Virtual environments
venv/
.venv/
env/

# Pytest / Coverage
.pytest_cache/
.coverage
htmlcov/
coverage.xml

# MyPy / Ruff
.mypy_cache/
.ruff_cache/

# Jupyter
.ipynb_checkpoints/

# ── Node / Frontend ──────────
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Next.js
.next/
out/

# Build output
frontend/dist/
frontend/build/

# Turbopack
.turbo/

# Vite
.vite/

# ── Docker & Deploy ──────────
docker-compose.override.yml
deploy/.env

# ── Logs ─────────────────────
logs/
*.log

# ── Data & Uploads ───────────
uploads/
data/
*.sqlite3
*.db

# ── Misc ─────────────────────
.cache/
.temp/
tmp/
*.bak
*.tmp
*.pid
*.seed

# ── CodeFlicker / AI IDE ─────
.codeflicker/
.codex/