# ── SupportForge 后端环境变量配置（Podman Compose 专用） ──
# 此模板专为 compose 场景定制，连接地址使用 compose 服务名而非 localhost
# 本地开发请使用 .env.example

# 应用配置
APP_NAME=SupportForge
APP_ENV=development
APP_PORT=8000

# 数据库 — compose 场景使用服务名 "postgres"
DATABASE_URL=postgresql+asyncpg://supportforge:supportforge_dev@postgres:5432/supportforge
DATABASE_URL_SYNC=postgresql://supportforge:supportforge_dev@postgres:5432/supportforge

# Redis — compose 场景使用服务名 "redis"
REDIS_URL=redis://redis:6379/0

# Qdrant — compose 场景使用服务名 "qdrant"
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION_NAME=supportforge_vectors

# JWT 认证
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL_NAME=gpt-4o-mini

# Celery — compose 场景使用服务名 "redis"
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# 日志
LOG_LEVEL=INFO