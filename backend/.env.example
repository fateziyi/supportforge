# ── SupportForge 后端环境变量配置 ──
# 复制此文件为 .env 并填入实际值

# 应用配置
APP_NAME=SupportForge
APP_ENV=development
APP_PORT=8000

# 数据库
DATABASE_URL=postgresql+asyncpg://supportforge:supportforge_dev@localhost:5432/supportforge
DATABASE_URL_SYNC=postgresql://supportforge:supportforge_dev@localhost:5432/supportforge

# Redis
REDIS_URL=redis://localhost:6379/0

# Qdrant
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=supportforge_vectors

# JWT 认证
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL_NAME=gpt-4o-mini

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# 日志
LOG_LEVEL=INFO